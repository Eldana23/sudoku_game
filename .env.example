# ============================================================
# SudokuMind — Environment Variables
# Copy this file to .env.local and fill in your values.
# All services are optional; the game layers in as you add them.
# ============================================================

# ----------------------------------------------------------
# SUPABASE — Auth, Leaderboards, Multiplayer, Friends
# Create a free project at https://supabase.com/
# Project Settings → API → Project URL & Anon Key
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------
# ANTHROPIC — AI Coach (streams via claude-opus-4-5)
# Get your key at https://console.anthropic.com/
# ----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------
# APP — General configuration
# ----------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------
# STRIPE — Pro subscriptions (optional)
# https://dashboard.stripe.com/apikeys
# ----------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_LIFETIME_PRICE_ID=price_...
